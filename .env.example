# ============================================
# EJEMPLO DE VARIABLES DE ENTORNO
# ============================================
# Este archivo SÍ se sube a Git como plantilla
# Copia este archivo a ".env" y llena con valores reales
# ============================================

# API Base URL
API_BASE_URL=http://localhost:3000

# Firebase Web Push (VAPID Key)
# Obtener de: Firebase Console > Project Settings > Cloud Messaging > Web Push certificates
VAPID_KEY=TU_VAPID_KEY_AQUI

# Resend API Key (para emails transaccionales)
# Obtener de: https://resend.com/api-keys
# RESEND_API_KEY=re_xxx

# Stripe Publishable Key (cuando integres pagos)
# Obtener de: https://dashboard.stripe.com/apikeys
# STRIPE_PUBLISHABLE_KEY=pk_xxx

# ============================================
# INSTRUCCIONES:
# 1. Copia este archivo: cp .env.example .env
# 2. Llena los valores reales en .env
# 3. NUNCA subas .env a Git (ya está en .gitignore)
# ============================================
