# =============================================================================
# RESEND CONFIGURATION (Primary Email Service)
# =============================================================================
# Get your API Key from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# SENDGRID CONFIGURATION (Legacy - Keep for Compatibility)
# =============================================================================
# Get your API Key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Verified sender email (must be verified in SendGrid)
# https://app.sendgrid.com/settings/sender_auth/senders
SENDGRID_FROM_EMAIL=no-reply@ayutthayacamp.cl
SENDGRID_FROM_NAME=Ayutthaya Camp

# =============================================================================
# APP CONFIGURATION
# =============================================================================
# Your app name for email branding
APP_NAME=Ayutthaya Camp

# Logo URL (publicly accessible)
APP_LOGO_URL=https://firebasestorage.googleapis.com/v0/b/ayuthaya-camp.firebasestorage.app/o/public%2Flogo-ayutthaya.jpeg?alt=media

# Company/Support info
SUPPORT_EMAIL=no-reply@ayutthayacamp.cl
COMPANY_ADDRESS=Chile

# =============================================================================
# AUTH CONFIGURATION
# =============================================================================
# Your Firebase project domain for action links
# Format: your-project.firebaseapp.com or your-custom-domain.com
ACTION_DOMAIN=ayuthaya-camp.firebaseapp.com

# =============================================================================
# ENVIRONMENT
# =============================================================================
NODE_ENV=production
