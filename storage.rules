rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ============================================
    // RECEIPTS - Comprobantes de pago
    // ============================================
    match /receipts/{userId}/{fileName} {
      // Permitir lectura a:
      // 1. El usuario dueño del comprobante
      // 2. Usuarios con rol admin
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );

      // Permitir escritura solo al usuario dueño
      allow write: if request.auth != null && request.auth.uid == userId &&
        // Validar tamaño del archivo (máximo 10MB)
        request.resource.size < 10 * 1024 * 1024 &&
        // Validar tipo de contenido
        (
          request.resource.contentType.matches('image/jpeg') ||
          request.resource.contentType.matches('image/png') ||
          request.resource.contentType.matches('application/pdf')
        );
    }

    // ============================================
    // PUBLIC - Archivos públicos (logos, imágenes estáticas)
    // ============================================
    match /public/{fileName} {
      // Permitir lectura pública para archivos en la carpeta public
      allow read: if true;

      // Permitir escritura solo a admins
      allow write: if request.auth != null &&
        exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ============================================
    // PROFILE PHOTOS - Fotos de perfil (avatares)
    // ============================================
    // La app guarda el avatar como profile_photos/<uid>.jpg, por lo que el
    // dueño se valida contra el nombre del archivo: solo el usuario
    // autenticado puede escribir SU propio archivo.
    match /profile_photos/{fileName} {
      // Cualquier usuario autenticado puede ver avatares
      // (se muestran en vistas de admin y perfiles)
      allow read: if request.auth != null;

      // Escritura solo del dueño, solo imágenes, máximo 5MB
      allow write: if request.auth != null &&
        fileName == request.auth.uid + '.jpg' &&
        request.resource.size < 5 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
    }

    // ============================================
    // Denegar todo lo demás
    // ============================================
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
